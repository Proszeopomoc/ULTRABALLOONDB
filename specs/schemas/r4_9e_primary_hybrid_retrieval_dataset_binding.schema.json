{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Proszeopomoc/ULTRABALLOONDB/specs/schemas/r4_9e_primary_hybrid_retrieval_dataset_binding.schema.json",
  "title": "UltraBalloonDB R4.9E primary hybrid retrieval dataset binding",
  "type": "object",
  "required": [
    "schema",
    "benchmark_identity",
    "frozen_at_base_head",
    "benchmark_execution_performed",
    "product_engine",
    "dataset",
    "upstream_facts_to_verify_at_intake",
    "claim_scope",
    "record_and_graph_mapping",
    "external_semantic_space",
    "native_structural_space",
    "temporal_snapshots",
    "ground_truth",
    "query_selection",
    "graph_scope_validation_grid",
    "ranking_paths",
    "full_hybrid_validation_weight_grid",
    "graph_profiles",
    "validation_and_test_lock",
    "metrics",
    "primary_pass_condition",
    "leakage_and_integrity_rules",
    "next_gate"
  ],
  "properties": {
    "schema": {
      "const": "ultraballoondb.r4_9e.primary_hybrid_retrieval_dataset_binding.v1"
    },
    "benchmark_identity": {
      "const": "ULTRABALLOONDB_PRIMARY_HYBRID_RETRIEVAL_BENCHMARK_V1"
    },
    "frozen_at_base_head": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "benchmark_execution_performed": {
      "const": false
    },
    "test_set_executed": {
      "const": false
    },
    "benchmark_claim_made": {
      "const": false
    },
    "product_engine": {
      "type": "object"
    },
    "dataset": {
      "type": "object"
    },
    "upstream_facts_to_verify_at_intake": {
      "type": "object"
    },
    "claim_scope": {
      "type": "object"
    },
    "record_and_graph_mapping": {
      "type": "object"
    },
    "external_semantic_space": {
      "type": "object"
    },
    "native_structural_space": {
      "type": "object"
    },
    "temporal_snapshots": {
      "type": "object"
    },
    "ground_truth": {
      "type": "object"
    },
    "query_selection": {
      "type": "object"
    },
    "graph_scope_validation_grid": {
      "type": "array",
      "minItems": 4
    },
    "ranking_paths": {
      "type": "array",
      "minItems": 5
    },
    "full_hybrid_validation_weight_grid": {
      "type": "array",
      "minItems": 1
    },
    "graph_profiles": {
      "type": "array",
      "minItems": 4
    },
    "validation_and_test_lock": {
      "type": "object"
    },
    "metrics": {
      "type": "object"
    },
    "primary_pass_condition": {
      "type": "object"
    },
    "leakage_and_integrity_rules": {
      "type": "array",
      "minItems": 10
    },
    "next_gate": {
      "const": "R4_9E1_OGBN_ARXIV_DATASET_INTAKE_LICENSE_AND_DIGEST_READ_ONLY"
    }
  },
  "additionalProperties": true
}
